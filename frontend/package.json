{
  "name": "proxkey-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:with-api": "concurrently -k -n vite,api -c cyan,magenta \"vite\" \"npm --prefix server run dev\"",
    "prod:cli-setup": "bash scripts/production-cli-setup.sh",
    "prod:cli-setup:railway": "bash scripts/production-cli-setup.sh railway",
    "prod:cli-setup:auth0": "bash scripts/production-cli-setup.sh auth0",
    "build": "tsc && vite build",
    "build:backend": "npm --prefix server run build",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "npm --prefix server run typecheck",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"server/src/**/*.ts\" \"*.{js,json,md,ts}\" \"server/*.{json,ts}\" \"scripts/**/*.{js,mjs}\" \".github/**/*.{yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"server/src/**/*.ts\" \"*.{js,json,md,ts}\" \"server/*.{json,ts}\" \"scripts/**/*.{js,mjs}\" \".github/**/*.{yml,yaml}\"",
    "test": "npm run test:backend",
    "test:backend": "npm --prefix server test",
    "check:env": "node scripts/validate-env-examples.mjs",
    "check:secrets": "node scripts/check-tracked-secrets.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high && npm --prefix server audit --omit=dev --audit-level=high",
    "ci:check": "npm run check:env && npm run check:secrets && npm run typecheck && npm run typecheck:backend && npm run lint && npm run format:check && npm run test && npm run build && npm run build:backend && npm run audit:prod",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "build:vite": "npm run build",
    "build:reset": "node scripts/build-reset-page.js",
    "build:production": "npm run build && npm run build:reset",
    "preview": "vite preview",
    "generate:og": "node scripts/generate-og-image.js",
    "debug:env": "node scripts/debug-env.js",
    "deploy:demo": "bash scripts/deploy-demo.sh",
    "smoke:demo": "bash scripts/smoke/test-demo.sh",
    "test:reset": "node scripts/test-production-reset.js",
    "test:production": "npm run test:reset"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.9",
    "@vercel/analytics": "^1.5.0",
    "dotenv": "^17.2.2",
    "motion": "^12.23.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "6.30.3",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.4.0",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.3.6"
  }
}
