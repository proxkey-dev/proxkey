# ProxKey Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# LEGACY SUPABASE CONFIGURATION
# =============================================================================
# These values are only needed for older demo/onboarding routes that still depend
# on Supabase. The main auth + dashboard flow now uses the Fastify backend below.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key for admin operations (server-side only)
# Keep this secret! Never commit this to version control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base URL for the Fastify backend used by the Vite frontend
VITE_API_BASE_URL=http://localhost:4000

# Base URL for your ProxKey marketing site / public app
NEXT_PUBLIC_BASE_URL=https://your-domain.com
VITE_BASE_URL=https://your-domain.com

# Cloudflare Worker URL for API operations
CLOUDFLARE_WORKER_URL=https://api.proxkey.dev

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Signing Keys (for key rotation)
# Current key - used for signing new tokens
# Format: JWK (JSON Web Key) for ES256, or PEM for other algorithms
JWT_CURRENT_KEY={"x":"YA8agB1XRFPaX5XppqqfV3Z-MgDNyUsuhtliFb0rglc","y":"qakv9me512PAnf9KBBEVorwF2o_Bg4mqZdGrj2SgOhE","alg":"ES256","crv":"P-256","ext":true,"kid":"9824f45d-4ec0-4209-af5d-7f3b60c734fb","kty":"EC","key_ops":["verify"]}

# Standby key - used for verification during key rotation
# Format: JWK (JSON Web Key) for ES256, or PEM for other algorithms
JWT_STANDBY_KEY=your-standby-jwt-key-here

# JWT Algorithm (ES256, RS256, HS256, etc.)
JWT_ALGORITHM=ES256

# JWT Token expiration time
JWT_EXPIRES_IN=1h

# Session secret for secure sessions
SESSION_SECRET=your-session-secret-here

# Key rotation settings
JWT_KEY_ROTATION_ENABLED=true
JWT_KEY_ROTATION_INTERVAL=30d

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================
# SMTP settings for sending emails
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=your-email-password

# Email templates base URL
EMAIL_TEMPLATES_URL=https://your-domain.com/emails

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database URL (if using direct database access)
DATABASE_URL=postgresql://username:password@localhost:5432/proxkey

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Set to 'development' for dev mode, 'production' for live
NODE_ENV=development

# Enable debug logging
DEBUG=false

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Stripe for payments (if using)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret

# Analytics (optional)
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================
# File upload limits
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/webp,image/svg+xml

# =============================================================================
# RATE LIMITING
# =============================================================================
# API rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
ENABLE_EMAIL_VERIFICATION=true
ENABLE_TWO_FACTOR_AUTH=true
ENABLE_ANALYTICS=false
ENABLE_DEBUG_MODE=false
