# =============================================================================
# ProxKey Frontend – Environment Variables
# Copy to .env for local development. .env.production is committed and contains
# only public (non-secret) config.
# =============================================================================

# API origin (required). Must point to the backend.
# Production value: https://api.proxkey.dev
VITE_API_BASE_URL=http://localhost:4000

# Auth0 SPA (needs these three vars in prod so “Continue with Auth0” works)
# Leave blank to use the local email/password login flow.
# Auth0 Dashboard: enable Refresh Token Rotation for this SPA application;
# authorize “offline_access” if you see consent / token errors.

VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.proxkey.dev
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/callback
