generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String?       @unique @db.Citext
  emailVerifiedAt DateTime?
  name            String?
  image           String?
  company         String?
  title           String?
  locale          String?       @default("en")
  timezone        String?
  metadata        Json
  phoneE164       String?       @unique
  phoneVerifiedAt DateTime?
  role            Role          @default(user)
  status          Status        @default(active)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  deletedAt       DateTime?
  twofaEnabled    Boolean       @default(false)
  totpEnabled     Boolean       @default(false)
  sms2faEnabled   Boolean       @default(false)
  accounts        Account[]
  apiKeys         ApiKey[]
  phoneOtps       PhoneOtp[]
  proxyRoutes     ProxyRoute[]
  sessions        Session[]
  security        UserSecurity?
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  provider          String
  providerAccountId String
  type              String
  access_token      String?
  token_type        String?
  scope             String?
  refresh_token     String?
  expires_at        Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model UserSecurity {
  userId              String              @id @db.Uuid
  totpSecretEnc       Bytes?
  recoveryCodesHashed String[]
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events              UserSecurityEvent[]
}

model UserSecurityEvent {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @db.Uuid
  event     String
  ip        String?
  userAgent String?
  createdAt DateTime     @default(now())
  security  UserSecurity @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model PhoneOtp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  phoneE164 String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, phoneE164])
}

model ApiKey {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String       @db.Uuid
  name        String
  slug        String       @unique
  keyMasked   String
  keyHash     String       @unique
  rpm         Int          @default(60)
  rpd         Int?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  lastUsedAt  DateTime?
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]

  @@index([ownerId])
  @@index([active])
}

model ProxyRoute {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String       @db.Uuid
  name        String
  targetUrl   String
  rateLimit   Int          @default(60)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]

  @@index([ownerId])
  @@index([active])
}

model RequestLog {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeId   String     @db.Uuid
  keyId     String?    @db.Uuid
  status    Int
  latencyMs Int
  ip        String?
  ua        String?
  ts        DateTime   @default(now())
  key       ApiKey?    @relation(fields: [keyId], references: [id])
  route     ProxyRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId, ts(sort: Desc)])
  @@index([keyId, ts(sort: Desc)])
  @@index([status])
}

enum Role {
  user
  admin
  owner
}

enum Status {
  active
  disabled
  deleted
}
