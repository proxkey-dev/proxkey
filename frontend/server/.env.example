# =============================================================================
# ProxKey Backend – Environment Variables
# Copy this file to .env and fill in your values.
# In production, set these in Railway's environment variable dashboard.
# NEVER commit .env with real secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://proxkey:proxkey@localhost:5432/proxkey

# ---------------------------------------------------------------------------
# Redis / queue (optional – enables background queue for cost attribution)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false
USE_INLINE_QUEUE=true

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
HOST=0.0.0.0
PORT=4000

# ---------------------------------------------------------------------------
# CORS – Canonical production setting
# Comma-separated list of allowed origins. Set this in Railway.
# Production: CORS_ALLOWED_ORIGINS=https://proxkey.dev,https://www.proxkey.dev
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# ---------------------------------------------------------------------------
# Session / cookie security (required in production)
# Generate with: openssl rand -base64 32
# ---------------------------------------------------------------------------
DASHBOARD_SESSION_SECRET=
JWT_SECRET=

# ---------------------------------------------------------------------------
# GitHub App (required for webhook-based CI cost attribution)
# ---------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# GitHub OAuth (required for "Sign in with GitHub" login flow)
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Auth0 (optional – enables Auth0 SPA and CLI device flow)
# If not set, local email/password login is used.
# ---------------------------------------------------------------------------
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.proxkey.dev
AUTH0_CLIENT_ID=your_spa_client_id
AUTH0_CLI_CLIENT_ID=your_cli_native_client_id
AUTH0_CLI_SCOPE=openid profile email offline_access

# ---------------------------------------------------------------------------
# Email (optional – enables weekly digest emails)
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
