# Copy to .env.railway.local (gitignored) and fill in values.
# Then: npm run prod:cli-setup:railway --prefix frontend   (or from frontend/: npm run prod:cli-setup:railway)
#
# Optional (same file or shell env):
#   RAILWAY_TOKEN=          # project token; use instead of `railway login` in CI
#   RAILWAY_SERVICE=        # service name if not linked
#   RAILWAY_ENVIRONMENT=    # e.g. production
#   AUTH0_TENANT=           # e.g. proxkey.us.auth0.com for auth0 CLI
#
# DATABASE_URL:
#   Paste your Postgres URL, or use a Railway reference, e.g.:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}

DATABASE_URL=

# openssl rand -base64 32  (required in production by the backend)
DASHBOARD_SESSION_SECRET=

# Optional; defaults to DASHBOARD_SESSION_SECRET if unset
JWT_SECRET=

# GitHub OAuth App (Developer Settings → OAuth Apps)
# Authorization callback URL in GitHub MUST be: https://proxkey.dev/github/callback
# (use your real marketing origin if different)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
