{
  "name": "@proxkey/proxkey-js",
  "version": "0.1.0",
  "description": "TypeScript client for the ProxKey API",
  "homepage": "https://proxkey.dev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "proxkey",
    "sdk",
    "typescript",
    "triage",
    "api"
  ]
}
